# =============================================================================
#  ARES environment configuration — copy to `.env` and fill in your values.
# =============================================================================
#   cp .env.example .env
# The real `.env` is gitignored and is NOT copied into the Docker image
# (see .dockerignore); it is injected at runtime via `--env-file .env`.

# --- LLM provider ------------------------------------------------------------
# "nvidia" (default, cloud NIM) or "ollama" (fully local).
LLM_PROVIDER="nvidia"

# NVIDIA NIM (required when LLM_PROVIDER=nvidia). Get a key at build.nvidia.com.
NVIDIA_API_KEY="your_nvidia_api_key_here"
NVIDIA_MODEL="meta/llama-3.3-70b-instruct"

# Ollama (used when LLM_PROVIDER=ollama).
# OLLAMA_MODEL="llama3.1:8b"
# Point the Ollama client at a non-default host (e.g. the compose sidecar).
# OLLAMA_HOST="http://ollama:11434"

# --- Persistence / checkpointing ---------------------------------------------
# "sqlite" (default, resumable) or "memory". In Docker these default into /data.
CHECKPOINT_BACKEND="sqlite"
CHECKPOINT_DB="ares_checkpoints.sqlite"

# --- Web search backend ------------------------------------------------------
# "duckduckgo" (default, keyless), "tavily", or "none".
SEARCH_BACKEND="duckduckgo"
# TAVILY_API_KEY="your_tavily_api_key_here"

# --- Retrieval limits --------------------------------------------------------
WEB_MAX_RESULTS=3
MAX_SOURCES_FOR_EXPERT=5
MAX_SOURCE_CHARS=1500

# --- CLI defaults (optional) -------------------------------------------------
# ARES_TOPIC="Renewable energy integration in microgrids"
# ARES_MAX_ANALYSTS=3
# ARES_MAX_TURNS=3
# ARES_OUTPUT="research_report.md"
